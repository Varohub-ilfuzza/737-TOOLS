# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está en .gitignore — NUNCA lo subas al repositorio.
#
# Uso en Flutter:
#   flutter run \
#     --dart-define=TG_TOKEN=$TG_TOKEN \
#     --dart-define=TG_CHAT_ID=$TG_CHAT_ID \
#     --dart-define=SHEETS_URL=$SHEETS_URL

TG_TOKEN=<telegram_bot_token>
TG_CHAT_ID=<telegram_chat_id>
SHEETS_URL=<google_apps_script_url>
